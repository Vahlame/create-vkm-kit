{
  "name": "vkm-kit",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "setup": "node scripts/agent-install.mjs",
    "setup:dry": "node scripts/agent-install.mjs --dry-run",
    "sync-agents": "npx --yes tsx scripts/sync-agents.ts",
    "sync-agents:check": "npx --yes tsx scripts/sync-agents.ts --check",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.checkjs.json",
    "license:sync": "node scripts/license-sync.mjs",
    "license:sync:check": "node scripts/license-sync.mjs --check",
    "linkcheck": "node scripts/linkcheck.mjs .",
    "preview:assets": "node scripts/preview-assets.mjs",
    "eval:adherence": "node evals/run-adherence-ci.mjs",
    "version:check": "node scripts/version.mjs check",
    "version:set": "node scripts/version.mjs set",
    "test": "npm run test --workspaces --if-present",
    "doctor": "node packages/vkm-doctor/src/doctor.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^26.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "yaml": "^2.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module"
}
