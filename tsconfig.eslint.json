{
  "//": "Type surface for typescript-eslint only (promise rules need type info). Not a gate — the CI-gated checkJs pass is tsconfig.checkjs.json, which scopes down to shipped src.",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "*.mjs",
    "packages/**/*.js",
    "packages/**/*.mjs",
    "scripts/**/*.mjs",
    "evals/**/*.mjs",
    "evals/**/*.cjs"
  ],
  "exclude": ["**/node_modules"]
}
